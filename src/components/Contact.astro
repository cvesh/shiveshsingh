---
import { Mail, Download } from 'lucide-static';
import { Github } from '../data/brandIcons';
---

<section id="contact" aria-labelledby="contact-heading" class="border-t border-line">
  <div class="mx-auto max-w-5xl px-6 py-24 md:py-32">
    <div class="reveal flex flex-col items-center text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">Get in touch</p>
      <h2 id="contact-heading" class="mt-3 max-w-2xl text-3xl font-bold tracking-tight text-body sm:text-4xl">
        Open to senior full-stack roles · Remote-friendly
      </h2>

      <a
        href="mailto:cvesh.singh@gmail.com"
        class="mt-10 inline-flex items-center gap-3 rounded-full bg-accent px-7 py-4 text-base font-semibold text-white shadow-[0_18px_40px_-16px_rgba(31,78,121,0.6)] transition hover:-translate-y-0.5 hover:bg-[#163d61]"
      >
        <span class="size-5 inline-flex items-center justify-center" set:html={Mail} />
        cvesh.singh@gmail.com
      </a>

      <ul class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <li>
          <a
            href="https://github.com/cvesh"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="inline-flex items-center gap-2 rounded-full border border-line bg-surface px-4 py-2 text-sm font-medium text-body transition hover:border-accent hover:text-accent"
          >
            <span class="size-4 inline-flex items-center justify-center" set:html={Github} />
            GitHub
          </a>
        </li>
        <li>
          <a
            href="/Shivesh_Lal_Singh_CV.pdf"
            aria-label="Download CV"
            class="inline-flex items-center gap-2 rounded-full border border-line bg-surface px-4 py-2 text-sm font-medium text-body transition hover:border-accent hover:text-accent"
          >
            <span class="size-4 inline-flex items-center justify-center" set:html={Download} />
            Download CV
          </a>
        </li>
      </ul>
    </div>
  </div>

  <footer class="border-t border-line">
    <div class="mx-auto max-w-5xl px-6 py-6 text-center text-xs text-muted">
      © 2026 Shivesh Lal Singh · Built with Astro
    </div>
  </footer>
</section>
