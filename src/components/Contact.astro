---
import Icon from './Icon.astro';

const email = 'cvesh.singh@gmail.com';
---

<section id="contact" aria-label="Contact">
  <div class="wrap inner">
    <div class="contact-grid">
      <div>
        <span class="eyebrow">
          <span class="dot"></span>
          <span class="mono num">08</span>
          <span>Get in touch</span>
        </span>
        <h2>Open to senior <br />full-stack roles.</h2>
        <p class="lede">Remote-friendly · Available from June 2026 · Based in Kathmandu, GMT+05:45.</p>
      </div>

      <div class="card">
        <div class="card-top">
          <div class="mono label">Primary</div>
          <a class="email-row" href={`mailto:${email}`}>
            <span class="email-text">{email}</span>
            <button class="copy-btn" type="button" data-email={email} aria-label="Copy email">
              <span class="icon-copy"><Icon name="copy" size={15} /></span>
              <span class="icon-check"><Icon name="check" size={16} /></span>
            </button>
          </a>
        </div>
        <hr class="rule" />
        <div class="tiles">
          <a class="tile" href="https://github.com/cvesh" target="_blank" rel="noopener noreferrer">
            <Icon name="github" size={18} />
            <span>github.com/cvesh</span>
            <span class="end"><Icon name="ext" size={13} /></span>
          </a>
          <a class="tile" href="https://linkedin.com/in/shiveshsingh" target="_blank" rel="noopener noreferrer">
            <Icon name="linkedin" size={18} />
            <span>linkedin · shiveshsingh</span>
            <span class="end"><Icon name="ext" size={13} /></span>
          </a>
          <a class="tile" href="/Shivesh_Lal_Singh_CV.pdf">
            <Icon name="download" size={18} />
            <span>Shivesh_Lal_Singh_CV.pdf</span>
            <span class="mono end">PDF</span>
          </a>
          <a class="tile" href="https://shiveshsingh.com.np">
            <Icon name="pin" size={18} />
            <span>shiveshsingh.com.np</span>
            <span class="mono end">NP</span>
          </a>
        </div>
      </div>
    </div>

    <hr class="rule footer-rule" />
    <div class="footer">
      <div class="mono">© 2026 Shivesh Lal Singh</div>
      <div class="mono">Built deliberately · Kathmandu, NP</div>
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.copy-btn');
  buttons.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const email = btn.dataset.email;
      if (!email || !navigator.clipboard) return;
      navigator.clipboard.writeText(email);
      btn.classList.add('copied');
      setTimeout(() => btn.classList.remove('copied'), 1800);
    });
  });
</script>

<style>
  .inner {
    padding: 120px 32px 80px;
    position: relative;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .num {
    color: var(--accent);
    font-weight: 700;
    margin-right: 6px;
  }
  h2 {
    margin: 24px 0 0;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.0;
    letter-spacing: -0.03em;
    font-weight: 800;
    color: var(--ink);
  }
  .lede {
    font-size: 16px;
    color: var(--muted);
    margin-top: 16px;
    max-width: 480px;
  }

  .card {
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: 16px;
    padding: 8px;
  }
  .card-top { padding: 24px 24px 16px; }
  .label {
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .email-row {
    margin-top: 8px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }
  .email-text {
    font-size: clamp(18px, 2.2vw, 24px);
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.01em;
    word-break: break-all;
  }
  .copy-btn {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    border: 1px solid var(--line);
    background: var(--bg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--ink);
    transition: color .2s;
    position: relative;
    flex-shrink: 0;
  }
  .copy-btn .icon-check { display: none; }
  .copy-btn.copied { color: #16A34A; }
  .copy-btn.copied .icon-copy { display: none; }
  .copy-btn.copied .icon-check { display: inline-flex; }

  .tiles {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--line);
  }
  .tile {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 16px 22px;
    background: var(--surface);
    font-size: 13px;
    color: var(--body);
    font-weight: 500;
  }
  .tile .end {
    color: var(--muted);
    font-size: 10px;
    display: inline-flex;
    align-items: center;
  }

  .footer-rule { margin-top: 96px; }
  .footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 12px;
    padding-top: 24px;
    color: var(--muted);
  }
  .footer .mono {
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 32px; }
    .tiles { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .inner { padding: 80px 20px 56px; }
    .footer-rule { margin-top: 64px; }
  }
</style>
