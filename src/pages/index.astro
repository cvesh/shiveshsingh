---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ANIMATED BACKGROUND -->
  <div class="bg-stage" aria-hidden="true">
    <span class="blob b1"></span>
    <span class="blob b2"></span>
    <span class="blob b3"></span>
    <span class="blob b4"></span>
  </div>
  <div class="dots" aria-hidden="true"></div>
  <div class="grain" aria-hidden="true"></div>

  <div class="page">

    <!-- TOP -->
    <header class="top a-in d1">
      <a href="#" class="mark" aria-label="Shivesh Singh">
        <span class="logo" aria-hidden="true">
          <svg class="logo-svg" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="logoGrad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%"  stop-color="#6FA8DC"/>
                <stop offset="55%" stop-color="#4A8BD4"/>
                <stop offset="100%" stop-color="#2A4E78"/>
              </linearGradient>
              <radialGradient id="logoSheen" cx="35%" cy="30%" r="55%">
                <stop offset="0%"  stop-color="#ffffff" stop-opacity="0.55"/>
                <stop offset="60%" stop-color="#ffffff" stop-opacity="0"/>
              </radialGradient>
              <filter id="logoGlow" x="-30%" y="-30%" width="160%" height="160%">
                <feGaussianBlur stdDeviation="1.2" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
            </defs>

            <rect x="2" y="2" width="44" height="44" rx="12" fill="url(#logoGrad)"/>
            <rect x="2" y="2" width="44" height="44" rx="12" fill="url(#logoSheen)"/>
            <rect x="4.5" y="4.5" width="39" height="39" rx="10" fill="none" stroke="rgba(255,255,255,0.18)" stroke-width="0.8"/>

            <g class="logo-orbit">
              <circle cx="24" cy="24" r="17.5" fill="none" stroke="rgba(255,255,255,0.22)" stroke-width="0.7" stroke-dasharray="1.5 3"/>
            </g>

            <g filter="url(#logoGlow)">
              <path d="M30.5 16.5 C 28 14.5, 20 14.5, 17.5 17 C 15 19.5, 16 22, 19 23 L 28 25 C 31 26, 32 28.5, 29.5 31 C 27 33.5, 19 33.5, 16.5 31.5"
                    fill="none" stroke="#ffffff" stroke-width="3.3" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M16.5 32 L 16.5 35.5 L 22 35.5" fill="none" stroke="#ffffff" stroke-width="3.3" stroke-linecap="round" stroke-linejoin="round" opacity="0.92"/>
            </g>

            <g class="logo-pulse">
              <circle cx="36" cy="12" r="2.6" fill="#FBBF24"/>
            </g>
          </svg>
        </span>
        <span class="mark-url">shiveshsingh.com.np</span>
      </a>
      <div class="available">
        <span class="pulse"></span>
        Available · 2026
      </div>
    </header>

    <!-- MAIN -->
    <main class="hero">

      <!-- LEFT — TEXT -->
      <div class="left">
        <div class="eyebrow a-up d2">Senior Full-Stack Engineer</div>

        <h1 class="name a-up d3">
          Shivesh
          <span class="accent">Singh.</span>
        </h1>

        <p class="role a-up d4">
          Building production web systems end-to-end <span class="sep"></span> Kathmandu, Nepal
        </p>

        <!-- STATS — 3 numbers, no clutter -->
        <div class="stats a-up d5">
          <div class="stat">
            <div class="stat-n">13<span class="plus">+</span></div>
            <div class="stat-l">Years</div>
          </div>
          <div class="stat">
            <div class="stat-n">6<span class="plus">+</span></div>
            <div class="stat-l">Projects</div>
          </div>
          <div class="stat">
            <div class="stat-n">3</div>
            <div class="stat-l">Companies</div>
          </div>
        </div>

        <!-- STACK — key tools as glyphs -->
        <div class="strip">
          <span class="strip-l">Stack</span>
          <div class="strip-items">
            <span class="pill" data-cat="fe">
              <span class="pill-dot"></span>React
              <span class="tip">
                <span class="tip-title">React</span>
                <span class="tip-meta"><span class="swatch" style="background:var(--c-fe)"></span>Frontend · 9 years</span>
                <span class="tip-desc">Hooks, suspense, server components. App-shell &amp; SaaS UIs at scale.</span>
              </span>
            </span>
            <span class="pill" data-cat="fe">
              <span class="pill-dot"></span>Next.js
              <span class="tip">
                <span class="tip-title">Next.js</span>
                <span class="tip-meta"><span class="swatch" style="background:var(--c-fe)"></span>Frontend · 6 years</span>
                <span class="tip-desc">App Router, edge/SSR, ISR. Production deploys at ZenLedger.</span>
              </span>
            </span>
            <span class="pill" data-cat="be">
              <span class="pill-dot"></span>Ruby on Rails
              <span class="tip">
                <span class="tip-title">Ruby on Rails</span>
                <span class="tip-meta"><span class="swatch" style="background:var(--c-be)"></span>Backend · 10 years</span>
                <span class="tip-desc">Architect of choice. Sidekiq jobs, REST/GraphQL APIs, scaling DB layers.</span>
              </span>
            </span>
            <span class="pill" data-cat="lang">
              <span class="pill-dot"></span>PHP
              <span class="tip">
                <span class="tip-title">PHP</span>
                <span class="tip-meta"><span class="swatch" style="background:var(--c-lang)"></span>Language · 6 years</span>
                <span class="tip-desc">PHP / CodeIgniter / WordPress era. Foundational web work since 2013.</span>
              </span>
            </span>
            <span class="pill" data-cat="be">
              <span class="pill-dot"></span>WordPress
              <span class="tip">
                <span class="tip-title">WordPress</span>
                <span class="tip-meta"><span class="swatch" style="background:var(--c-be)"></span>Backend · 6 years</span>
                <span class="tip-desc">Custom theme development, plugin work, content workflows for corporate sites.</span>
              </span>
            </span>
            <span class="pill" data-cat="db">
              <span class="pill-dot"></span>PostgreSQL
              <span class="tip">
                <span class="tip-title">PostgreSQL</span>
                <span class="tip-meta"><span class="swatch" style="background:var(--c-db)"></span>Database · 9 years</span>
                <span class="tip-desc">Indexing, partitioning, query plans. Comfortable with millions of rows.</span>
              </span>
            </span>
            <span class="pill" data-cat="cloud">
              <span class="pill-dot"></span>AWS
              <span class="tip">
                <span class="tip-title">AWS</span>
                <span class="tip-meta"><span class="swatch" style="background:var(--c-cloud)"></span>Cloud · 8 years</span>
                <span class="tip-desc">EC2, RDS, S3, Lambda. Zero-downtime deploys via Capistrano &amp; CodeDeploy.</span>
              </span>
            </span>
          </div>
        </div>

        <!-- WORK — name + tooltip -->
        <div class="strip">
          <span class="strip-l">Work</span>
          <div class="strip-items">
            <a href="https://www.zenledger.io/" target="_blank" rel="noopener noreferrer" class="pill work featured">
              <span class="pill-mono">ZL</span>ZenLedger
              <span class="tip">
                <span class="tip-title">ZenLedger</span>
                <span class="tip-meta"><span class="swatch" style="background:var(--accent)"></span>Senior Full-Stack · 2018 → 2026</span>
                <span class="tip-desc">Crypto-tax SaaS — millions of transactions, 400+ exchange integrations, tax-form generation.</span>
                <span class="tip-tags">
                  <span>Next.js</span><span>Rails</span><span>Go</span><span>Postgres</span><span>AWS</span>
                </span>
                <span class="tip-link">Visit ↗</span>
              </span>
            </a>
            <a href="https://airscoutenterprise.textron.com/" target="_blank" rel="noopener noreferrer" class="pill work">
              <span class="pill-mono">AS</span>AirScout
              <span class="tip">
                <span class="tip-title">AirScout Enterprise Cloud</span>
                <span class="tip-meta"><span class="swatch" style="background:var(--accent)"></span>Backend · 2016 → 2018</span>
                <span class="tip-desc">Cloud API for signal-heatmap processing and automated PDF reporting at Textron.</span>
                <span class="tip-tags"><span>Rails</span><span>Postgres</span><span>AWS</span></span>
                <span class="tip-link">Visit ↗</span>
              </span>
            </a>
            <a href="https://github.com/cvesh/twitchscrape" target="_blank" rel="noopener noreferrer" class="pill work">
              <span class="pill-mono">TS</span>TwitchScrape
              <span class="tip">
                <span class="tip-title">TwitchScrape</span>
                <span class="tip-meta"><span class="swatch" style="background:var(--accent)"></span>Open source · 2017</span>
                <span class="tip-desc">Scrapes and visualises public Twitch data — API backend with a React frontend.</span>
                <span class="tip-tags"><span>React</span><span>Rails</span></span>
                <span class="tip-link">View on GitHub ↗</span>
              </span>
            </a>
            <a href="https://bajratechnologies.com/home" target="_blank" rel="noopener noreferrer" class="pill work">
              <span class="pill-mono">BT</span>Bajra
              <span class="tip">
                <span class="tip-title">Bajra Technologies</span>
                <span class="tip-meta"><span class="swatch" style="background:var(--accent)"></span>Frontend · 2017</span>
                <span class="tip-desc">Company marketing site — AngularJS frontend backed by an API service.</span>
                <span class="tip-tags"><span>AngularJS</span><span>Rails</span></span>
                <span class="tip-link">Visit ↗</span>
              </span>
            </a>
            <a href="http://www.yatrikathmandusuite.com/" target="_blank" rel="noopener noreferrer" class="pill work">
              <span class="pill-mono">YK</span>Yatri KTM
              <span class="tip">
                <span class="tip-title">Yatri Kathmandu Suite</span>
                <span class="tip-meta"><span class="swatch" style="background:var(--accent)"></span>Web Developer · 2014</span>
                <span class="tip-desc">Hotel website with booking enquiry flows in PHP/CodeIgniter.</span>
                <span class="tip-tags"><span>PHP</span><span>CodeIgniter</span><span>MySQL</span></span>
                <span class="tip-link">Visit ↗</span>
              </span>
            </a>
            <a href="https://www.propak.com/" target="_blank" rel="noopener noreferrer" class="pill work">
              <span class="pill-mono">PP</span>Propak
              <span class="tip">
                <span class="tip-title">Propak</span>
                <span class="tip-meta"><span class="swatch" style="background:var(--accent)"></span>Web Developer · 2013</span>
                <span class="tip-desc">Corporate WordPress site with custom theme and content workflows.</span>
                <span class="tip-tags"><span>WordPress</span><span>PHP</span><span>MySQL</span></span>
                <span class="tip-link">Visit ↗</span>
              </span>
            </a>
          </div>
        </div>

        <!-- CTA -->
        <div class="cta">
          <a href="mailto:cvesh.singh@gmail.com" class="icon-btn" aria-label="Email" title="cvesh.singh@gmail.com">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3.5 6.5 8.5 7 8.5-7"/></svg>
          </a>
          <a href="https://github.com/cvesh" target="_blank" rel="noopener noreferrer" class="icon-btn" aria-label="GitHub" title="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-3.2 19.5c.5.1.7-.2.7-.5v-1.8c-2.8.6-3.4-1.2-3.4-1.2-.5-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.5 2.3 1.1 2.9.8.1-.6.3-1.1.6-1.3-2.2-.3-4.6-1.1-4.6-5a4 4 0 0 1 1-2.7c-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1a9.4 9.4 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7a4 4 0 0 1 1 2.7c0 3.9-2.4 4.7-4.6 5 .4.3.7.9.7 1.8v2.7c0 .3.2.6.7.5A10 10 0 0 0 12 2Z"/></svg>
          </a>
          <a href="https://linkedin.com/in/shiveshsingh" target="_blank" rel="noopener noreferrer" class="icon-btn" aria-label="LinkedIn" title="LinkedIn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 10v7M8 7v.01M12 17v-4a2 2 0 0 1 4 0v4M12 10v7"/></svg>
          </a>
        </div>
      </div>

      <!-- RIGHT — PHOTO -->
      <div class="right">
        <div class="photo float">
          <span class="photo-tag">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-6.2-7-11a7 7 0 1 1 14 0c0 4.8-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
            Kathmandu, NP
          </span>
        </div>
      </div>
    </main>

  </div>
</Layout>
